# Este archivo es privado, JAMAS debe publicarse en GitHub.
# Para configurar tu máquina local, renombra este archivo a `.env` y llena los datos:

# 1. Tu URL de Alchemy (Aplicación Ethereum Sepolia)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY_AQUI"

# 2. La Llave Privada de tu Billetera de MetaMask (Debe ser la billetera "Admin" que despliega el contrato)
# Para obtenerla: MetaMask > Cuenta > Detalles de Cuentas > Mostrar clave privada
# ¡ADVERTENCIA! NUNCA PONGAS LA CLAVE DE UNA CUENTA CON ETHER REAL. DEBE SER UNA CUENTA DE JUGUETE/TESTNET.
PRIVATE_KEY="0x_TU_LLAVE_PRIVADA_AQUI"
